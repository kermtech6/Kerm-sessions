{
  "version": 2,
  "functions": {
    "prince.js": {
      "runtime": "@vercel/node",
      "memory": 3008,
      "maxDuration": 300
    }
  },
  "routes": [
    {
      "src": "/socket.io/(.*)",
      "dest": "/prince.js"
    },
    {
      "src": "/api/(.*)",
      "dest": "/prince.js"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/public/(.*)",
      "dest": "/public/$1"
    },
    {
      "src": "/(.*\\.(css|js|png|jpg|jpeg|gif|svg|ico|webp|woff|woff2|ttf|eot))",
      "dest": "/public/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/prince.js"
    }
  ]
}
